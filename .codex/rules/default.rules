# Safe repo inspection can run without an extra approval prompt.
prefix_rule(
    pattern = ["rtk", "rg"],
    decision = "allow",
    justification = "Read-only repository search is safe for routine inspection.",
    match = ["rtk rg -n \"probe\" drivers"],
)

prefix_rule(
    pattern = ["rtk", "sed"],
    decision = "allow",
    justification = "Read-only file excerpts are safe for routine inspection.",
    match = ["rtk sed -n '1,120p' AGENTS.md"],
)

prefix_rule(
    pattern = ["rtk", "find"],
    decision = "allow",
    justification = "Read-only repository discovery is safe for routine inspection.",
    match = ["rtk find . -maxdepth 2 -type f"],
)

prefix_rule(
    pattern = ["rtk", "git", "status"],
    decision = "allow",
    justification = "Git status is read-only and useful before edits.",
    match = ["rtk git status --short"],
)

prefix_rule(
    pattern = ["rtk", "git", "diff"],
    decision = "allow",
    justification = "Git diff is read-only and useful for review.",
    match = ["rtk git diff -- .codex"],
)

prefix_rule(
    pattern = ["rtk", "git", "show"],
    decision = "allow",
    justification = "Git show is read-only and useful for history inspection.",
    match = ["rtk git show --stat HEAD"],
)

prefix_rule(
    pattern = ["rtk", "git", "log"],
    decision = "allow",
    justification = "Git log is read-only and useful for history inspection.",
    match = ["rtk git log --oneline -5"],
)

# Build, static-analysis, and live-board commands can mutate artifacts or touch hardware.
prefix_rule(
    pattern = ["rtk", "make"],
    decision = "prompt",
    justification = "Build and flash targets may write artifacts or touch hardware.",
    match = ["rtk make kernel", "rtk make flash DEV=/dev/sdb"],
)

prefix_rule(
    pattern = ["rtk", "cppcheck"],
    decision = "prompt",
    justification = "Static analysis is usually safe but can be expensive on this BSP tree.",
    match = ["rtk cppcheck --enable=all drivers/led-gpio/led-gpio.c"],
)

prefix_rule(
    pattern = ["rtk", "python3", "scripts/bbb-uart.py"],
    decision = "prompt",
    justification = "UART debug commands interact with live board state.",
    match = ["rtk python3 scripts/bbb-uart.py capture --timeout 60"],
)

prefix_rule(
    pattern = ["rtk", "./scripts/bbb-uart.py"],
    decision = "prompt",
    justification = "UART debug commands interact with live board state.",
    match = ["rtk ./scripts/bbb-uart.py capture --timeout 60"],
)

prefix_rule(
    pattern = ["rtk", "minicom"],
    decision = "prompt",
    justification = "Serial console commands interact with live board state.",
    match = ["rtk minicom -D /dev/ttyUSB0 -b 115200"],
)

prefix_rule(
    pattern = ["rtk", "screen"],
    decision = "prompt",
    justification = "Serial console commands interact with live board state.",
    match = ["rtk screen /dev/ttyUSB0 115200"],
)

prefix_rule(
    pattern = ["rtk", "ssh"],
    decision = "prompt",
    justification = "Remote target access can change board state.",
    match = ["rtk ssh root@192.168.7.2 uname -a"],
)

prefix_rule(
    pattern = ["rtk", "scp"],
    decision = "prompt",
    justification = "Remote file copy can change board state.",
    match = ["rtk scp build/kernel/zImage root@192.168.7.2:/boot/"],
)

prefix_rule(
    pattern = ["rtk", "rsync"],
    decision = "prompt",
    justification = "Remote sync can change board or host state.",
    match = ["rtk rsync -av build/ root@192.168.7.2:/boot/"],
)

prefix_rule(
    pattern = ["rtk", "./scripts/flash_sd.sh"],
    decision = "prompt",
    justification = "Flash script repartitions disks and is destructive.",
    match = ["rtk ./scripts/flash_sd.sh /dev/sdb"],
)

prefix_rule(
    pattern = ["rtk", "scripts/flash_sd.sh"],
    decision = "prompt",
    justification = "Flash script repartitions disks and is destructive.",
    match = ["rtk scripts/flash_sd.sh /dev/sdb"],
)

# Raw disk tools stay blocked even if requested without project wrappers.
prefix_rule(
    pattern = ["dd"],
    decision = "forbidden",
    justification = "Raw disk writes are destructive; use reviewed project flash workflow instead.",
    match = ["dd if=/dev/zero of=/dev/sdb"],
)

prefix_rule(
    pattern = ["mkfs"],
    decision = "forbidden",
    justification = "Filesystem creation is destructive; use reviewed project flash workflow instead.",
    match = ["mkfs /dev/sdb2"],
)

prefix_rule(
    pattern = ["mkfs.ext4"],
    decision = "forbidden",
    justification = "Filesystem creation is destructive; use reviewed project flash workflow instead.",
    match = ["mkfs.ext4 /dev/sdb2"],
)

prefix_rule(
    pattern = ["mkfs.vfat"],
    decision = "forbidden",
    justification = "Filesystem creation is destructive; use reviewed project flash workflow instead.",
    match = ["mkfs.vfat /dev/sdb1"],
)

prefix_rule(
    pattern = ["mkfs.fat"],
    decision = "forbidden",
    justification = "Filesystem creation is destructive; use reviewed project flash workflow instead.",
    match = ["mkfs.fat /dev/sdb1"],
)

prefix_rule(
    pattern = ["fdisk"],
    decision = "forbidden",
    justification = "Partition editing is destructive; use reviewed project flash workflow instead.",
    match = ["fdisk /dev/sdb"],
)

prefix_rule(
    pattern = ["sfdisk"],
    decision = "forbidden",
    justification = "Partition editing is destructive; use reviewed project flash workflow instead.",
    match = ["sfdisk /dev/sdb"],
)

prefix_rule(
    pattern = ["parted"],
    decision = "forbidden",
    justification = "Partition editing is destructive; use reviewed project flash workflow instead.",
    match = ["parted /dev/sdb print"],
)

prefix_rule(
    pattern = ["wipefs"],
    decision = "forbidden",
    justification = "Filesystem signature wiping is destructive; use reviewed project flash workflow instead.",
    match = ["wipefs -a /dev/sdb"],
)

prefix_rule(
    pattern = ["blkdiscard"],
    decision = "forbidden",
    justification = "Block discard is destructive; use reviewed project flash workflow instead.",
    match = ["blkdiscard /dev/sdb"],
)

prefix_rule(
    pattern = ["rtk", "dd"],
