# Block broad staging in this dirty BSP workspace.
prefix_rule(
    pattern = ["git", "add", [".", "-A"]],
    decision = "forbidden",
    justification = "Use exact-path staging; broad staging can capture build artifacts and local files.",
    match = ["git add .", "git add -A"],
    not_match = ["git add AGENTS.md"],
)

prefix_rule(
    pattern = ["rtk", "git", "add", [".", "-A"]],
    decision = "forbidden",
    justification = "Use exact-path staging; broad staging can capture build artifacts and local files.",
    match = ["rtk git add .", "rtk git add -A"],
    not_match = ["rtk git add AGENTS.md"],
)

# Block direct disk-mutating tools; use reviewed project flash workflows instead.
prefix_rule(
    pattern = [["dd", "fdisk", "sfdisk", "parted", "wipefs", "mkfs", "mkfs.ext4", "mkfs.vfat", "mkfs.fat"]],
    decision = "forbidden",
    justification = "Direct disk mutation is destructive; use the reviewed project flash workflow with explicit approval.",
    match = ["dd if=image of=/dev/sdb", "sfdisk /dev/sdb", "mkfs.ext4 /dev/sdb2"],
)

prefix_rule(
    pattern = ["rtk", ["dd", "fdisk", "sfdisk", "parted", "wipefs", "mkfs", "mkfs.ext4", "mkfs.vfat", "mkfs.fat"]],
    decision = "forbidden",
    justification = "Direct disk mutation is destructive; use the reviewed project flash workflow with explicit approval.",
    match = ["rtk dd if=image of=/dev/sdb", "rtk sfdisk /dev/sdb", "rtk mkfs.ext4 /dev/sdb2"],
)

# Prompt before expensive builds, live-board access, or privilege escalation.
prefix_rule(
    pattern = ["rtk", "make"],
    decision = "prompt",
    justification = "Build, deploy, flash, and clean targets may write artifacts or touch hardware.",
    match = ["rtk make kernel", "rtk make flash DEV=/dev/sdb"],
)

prefix_rule(
    pattern = ["rtk", "docker"],
    decision = "prompt",
    justification = "Docker commands can be expensive and may write build artifacts.",
    match = ["rtk docker ps", "rtk docker build -t bbb-builder ."],
)

prefix_rule(
    pattern = ["rtk", ["ssh", "scp", "rsync"]],
    decision = "prompt",
    justification = "Remote board access can mutate live target state.",
    match = ["rtk ssh root@192.168.7.2", "rtk scp zImage root@192.168.7.2:/boot/", "rtk rsync -av build/ root@192.168.7.2:/boot/"],
)

prefix_rule(
    pattern = ["rtk", ["minicom", "screen"]],
    decision = "prompt",
    justification = "Serial console commands interact with live board state.",
    match = ["rtk minicom -D /dev/ttyUSB0 -b 115200", "rtk screen /dev/ttyUSB0 115200"],
)

prefix_rule(
    pattern = ["rtk", "python3", "scripts/debug/bbb-uart.py"],
    decision = "prompt",
    justification = "UART debug commands interact with live board state.",
    match = ["rtk python3 scripts/debug/bbb-uart.py capture-boot --timeout 60"],
)

prefix_rule(
    pattern = ["rtk", "./scripts/debug/bbb-uart.py"],
    decision = "prompt",
    justification = "UART debug commands interact with live board state.",
    match = ["rtk ./scripts/debug/bbb-uart.py capture-boot --timeout 60"],
)

prefix_rule(
    pattern = ["sudo"],
    decision = "prompt",
    justification = "sudo can bypass sandbox protections and run destructive media operations.",
    match = ["sudo bash scripts/control/flash_sd.sh /dev/sdb"],
)
