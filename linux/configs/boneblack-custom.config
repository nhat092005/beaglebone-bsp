# BeagleBone Black custom kernel config fragment
# Apply on top of am335x_boneblack_defconfig via:
#   scripts/kconfig/merge_config.sh -m .config linux/configs/boneblack-custom.config
# Or via Yocto SRC_URI as a .cfg fragment.

# Userspace I2C access (/dev/i2c-N)
CONFIG_I2C_CHARDEV=y

# sysfs GPIO interface (/sys/class/gpio/)
CONFIG_GPIO_SYSFS=y

# AM335x EHRPWM driver
CONFIG_PWM_TIEHRPWM=y

# TMP102 I2C temperature sensor
CONFIG_SENSORS_TMP102=y

# NOTE: CONFIG_PREEMPT_RT requires separate rt-patches applied to the kernel
# source tree before enabling. Not set here — enable manually after patching:
# CONFIG_PREEMPT_RT=y

# Runtime debug control (dynamic_debug)
CONFIG_DYNAMIC_DEBUG=y

# Kernel GDB stub via serial console (ttyO0)
CONFIG_KGDB=y
CONFIG_KGDB_SERIAL_CONSOLE=y
