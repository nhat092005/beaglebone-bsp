# BeagleBone Black custom kernel config fragment
# Apply on top of am335x_boneblack_defconfig via:
#   scripts/kconfig/merge_config.sh -m .config linux/configs/boneblack-custom.config
# Or via Yocto SRC_URI as a .cfg fragment.

CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_OMAP=y
CONFIG_HWMON=y
CONFIG_PWM=y
CONFIG_PWM_TIECAP=y
CONFIG_PWM_TIEHRPWM=y
CONFIG_DEBUG_FS=y
CONFIG_DEBUG_KERNEL=y
CONFIG_PROVE_LOCKING=y
CONFIG_KASAN=y
