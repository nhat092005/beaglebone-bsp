{
  "permissions": {
    "allow": []
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.claude/hooks/notify.sh\"'",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Send a notification + beep sound when Claude stops and waits for input.",
        "id": "stop:notify-vi"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.claude/hooks/notify.sh\"'",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Send a notification + beep sound when session ends.",
        "id": "session-end:notify-vi"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.claude/hooks/clang-format.sh\"'",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Automatically run clang-format on .c/.h files after writing/editing.",
        "id": "post-write:clang-format"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.claude/hooks/checkpatch.sh\"'",
            "timeout": 15
          }
        ],
        "description": "Run kernel checkpatch on .c/.h files in linux/ or drivers/ after writing/editing.",
        "id": "post-write:checkpatch"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.claude/hooks/block-git-add-all.sh\"'",
            "timeout": 5
          }
        ],
        "description": "Block git add -A and git add . to avoid committing build artifacts.",
        "id": "pre-bash:block-git-add-all"
      }
    ]
  }
}
