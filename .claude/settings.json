{
  "permissions": {
    "allow": [
      "Bash(python3 scripts/bbb-uart.py *)",
      "Bash(python3 /home/nhat/Working_Space/my-project/beaglebone-bsp/scripts/bbb-uart.py *)",
      "Bash(./scripts/bbb-uart.py *)",
      "Bash(ls /dev/ttyUSB*)",
      "Bash(ls -la /dev/ttyUSB*)",
      "Bash(test -f config/error-patterns.yaml)",
      "Bash(test -x scripts/bbb-uart.py)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Thông báo tiếng Việt + beep khi Claude dừng chờ input.",
        "id": "stop:notify-vi"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Thông báo tiếng Việt + beep khi session kết thúc.",
        "id": "session-end:notify-vi"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/clang-format.sh",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Tự động clang-format file .c/.h sau khi write/edit.",
        "id": "post-write:clang-format"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/checkpatch.sh",
            "timeout": 15
          }
        ],
        "description": "Chạy kernel checkpatch trên file .c/.h trong linux/ hoặc drivers/ sau khi write/edit.",
        "id": "post-write:checkpatch"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-git-add-all.sh",
            "timeout": 5
          }
        ],
        "description": "Chặn git add -A và git add . để tránh commit build artifacts.",
        "id": "pre-bash:block-git-add-all"
      }
    ]
  }
}
