From b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3 Mon Sep 17 00:00:00 2001
From: BeagleBone BSP <bsp@example.com>
Date: Wed, 16 Apr 2026 00:00:01 +0000
Subject: [PATCH 2/2] configs: am335x_evm: reduce boot delay to 1 s

Upstream default is 2 s. Reduce to 1 s to speed up boot cycle during
development. Still leaves enough time to interrupt for U-Boot prompt.

Signed-off-by: BeagleBone BSP <bsp@example.com>
---
 configs/am335x_evm_defconfig | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configs/am335x_evm_defconfig b/configs/am335x_evm_defconfig
index 1234567..89abcde 100644
--- a/configs/am335x_evm_defconfig
+++ b/configs/am335x_evm_defconfig
@@ -1,7 +1,7 @@
 CONFIG_ARM=y
 CONFIG_ARCH_OMAP2PLUS=y
 CONFIG_TI_COMMON_CMD_OPTIONS=y
 CONFIG_AM33XX=y
 CONFIG_TARGET_AM335X_EVM=y
 CONFIG_DEFAULT_DEVICE_TREE="am335x-boneblack"
-CONFIG_BOOTDELAY=2
+CONFIG_BOOTDELAY=1
 CONFIG_SPL=y
--
2.34.1
