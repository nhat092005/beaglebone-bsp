From a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2 Mon Sep 17 00:00:00 2001
From: BeagleBone BSP <bsp@example.com>
Date: Wed, 16 Apr 2026 00:00:00 +0000
Subject: [PATCH 1/2] arm: am335x: add TFTP boot env for dev workflow

Add serverip, ipaddr, and tftp_boot environment variables to
am335x_evm board config. This enables network boot during development:
  dhcp zImage from server, tftp dtb, bootz.

Signed-off-by: BeagleBone BSP <bsp@example.com>
---
 include/configs/am335x_evm.h | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/include/configs/am335x_evm.h b/include/configs/am335x_evm.h
index abc1234..def5678 100644
--- a/include/configs/am335x_evm.h
+++ b/include/configs/am335x_evm.h
@@ -40,6 +40,24 @@
 #ifndef __CONFIG_AM335X_EVM_H
 #define __CONFIG_AM335X_EVM_H

+/* Dev network defaults — override via uEnv.txt or setenv */
+#define CONFIG_SERVERIP		192.168.1.1
+#define CONFIG_IPADDR		192.168.1.100
+
+#define TFTP_BOOT_CMD \
+	"tftp_boot=" \
+		"dhcp ${loadaddr} zImage; " \
+		"tftp ${fdtaddr} am335x-boneblack.dtb; " \
+		"bootz ${loadaddr} - ${fdtaddr}\0"
+
 #include <configs/ti_armv7_common.h>

 /* Clock Defines */
@@ -50,6 +68,6 @@
 #define CONFIG_EXTRA_ENV_SETTINGS \
 	DEFAULT_LINUX_BOOT_ENV \
 	DEFAULT_MMC_TI_ARGS \
-	DEFAULT_FIT_TI_ARGS
+	DEFAULT_FIT_TI_ARGS \
+	TFTP_BOOT_CMD

 #endif /* ! __CONFIG_AM335X_EVM_H */
--
